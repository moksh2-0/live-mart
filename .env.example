# Copy this file to .env and fill in real values. .env is gitignored and never committed.

# --- Google OAuth (optional - app falls back to mock/simulated login if unset) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8501/OAuth_Callback

# --- Facebook OAuth (optional) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8501/OAuth_Callback

# --- Gmail SMTP for order/notification emails (optional) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=
SENDER_PASSWORD=

# --- Google Maps / Geocoding (optional - app falls back to text-based location matching) ---
GOOGLE_MAPS_API_KEY=
DEFAULT_LATITUDE=17.54
DEFAULT_LONGITUDE=78.57
